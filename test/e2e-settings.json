{
    // e2e 專用 app 設定（JSON5）：與 ./settings.json 相同, 唯 archiveAfterDays 設 0 停用封存掃描。
    // why: demo 種子時間戳為固定值 2026-01-01（baseline 確定性所需, 見 g.initialData.mjs 註解）,
    // 距今必逾封存齡 → 若封存掃描啟用, backend 起動 30s 後種子即被搬冷表, e2e/baseline 失去確定性。
    // 封存邏輯本身由 unit-procCore(archiveSweep) 與 api-agent(G1) 覆蓋。

    showLanguage: 'y',
    language: 'eng',
    serverPort: 11008,

    logFd: './logs',
    logInterval: 'hr',

    // 停用封存掃描（e2e 確定性）
    archiveAfterDays: 0,

}
